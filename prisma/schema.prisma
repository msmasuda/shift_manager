// 将来の企業・団体別対応のため組織を用意
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String  @id @default(cuid())
  name      String
  openTime   String? // "HH:MM" 営業開始・昼の部（デフォルト）
  closeTime  String? // "HH:MM" 営業終了・昼の部（デフォルト）
  openTime2  String? // "HH:MM" 営業開始・夜の部（デフォルト）
  closeTime2 String? // "HH:MM" 営業終了・夜の部（デフォルト）
  users        User[]
  scheduleDays ScheduleDay[]
}

model User {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  name           String
  role           UserRole @default(MEMBER)
  shiftAssignments ShiftAssignment[]
  leaveRecords     LeaveRecord[]
  @@unique([organizationId, email])
  @@index([organizationId])
}

enum UserRole {
  ADMIN
  MEMBER
}

enum LeaveType {
  PREFERRED_OFF // 希望休
  PAID_LEAVE    // 有給
}

// 日付ごとの設定（その日の最低出勤人数・営業時間）
model ScheduleDay {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date
  minRequired    Int      @default(1) // その日の最低出勤人数
  isHoliday      Boolean  @default(false)
  openTime       String?  // 組織デフォルトを上書きする営業開始時刻・昼の部
  closeTime      String?  // 組織デフォルトを上書きする営業終了時刻・昼の部
  openTime2      String?  // 組織デフォルトを上書きする営業開始時刻・夜の部
  closeTime2     String?  // 組織デフォルトを上書きする営業終了時刻・夜の部
  shiftAssignments ShiftAssignment[]
  @@unique([organizationId, date])
  @@index([organizationId])
}

// 希望休・有給の記録
model LeaveRecord {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime  @db.Date
  type           LeaveType
  @@unique([userId, date])
  @@index([organizationId])
  @@index([userId])
}

// シフト割り当て（誰がいつ〜いつ入るか）
model ShiftAssignment {
  id            String   @id @default(cuid())
  scheduleDayId String
  scheduleDay   ScheduleDay @relation(fields: [scheduleDayId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime     String   // "09:00" 形式
  endTime       String   // "18:00" 形式
  @@index([scheduleDayId])
  @@index([userId])
}
