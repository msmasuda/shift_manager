# データベース接続用の環境変数（Prismaが使用）
# ローカル環境のデフォルト値。必要に応じてパスワードなどを変更してください。
DATABASE_URL="postgresql://shift_manager:shift_manager@192.168.100.2:5432/shift_manager?schema=public"

# フロントエンドのAPIエンドポイント設定（空の場合は同一オリジンのNext.js Route Handlersを参照します）
# NEXT_PUBLIC_API_URL=

# 認証（Auth.js v5）
# openssl rand -base64 32 で生成
AUTH_SECRET=""
# Google Cloud Console で取得: https://console.cloud.google.com/
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
